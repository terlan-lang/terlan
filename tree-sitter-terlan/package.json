{
  "name": "tree-sitter-terlan",
  "version": "0.0.5",
  "description": "Tree-sitter grammar scaffold for Terlan source and template headers.",
  "license": "MIT OR Apache-2.0",
  "main": "grammar.js",
  "files": [
    "README.md",
    "grammar.js",
    "queries",
    "test/corpus"
  ],
  "tree-sitter": [
    {
      "scope": "source.terlan",
      "file-types": [
        "terl",
        "terli",
        "terl.html",
        "terl.md",
        "terl.json",
        "terl.toml",
        "terl.yaml",
        "terl.yml",
        "terl.txt"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "devDependencies": {
    "tree-sitter-cli": "^0.22.6"
  },
  "scripts": {
    "check": "node -c grammar.js && node -c test/pack_dry_run_test.js && node test/package_smoke_test.js",
    "check:cli": "npm run generate && npm test",
    "generate": "tree-sitter generate",
    "pack:dry-run": "npm pack --dry-run --json",
    "test": "tree-sitter test"
  }
}
