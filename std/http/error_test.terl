module std.http.ErrorTest.

import std.http.Error.{code, message, new, status}.
import type std.http.Error.HttpError.

pub type InvalidBody =
    Atom["invalid_body"].

pub sample_error(): HttpError ->
    new(InvalidBody, "invalid request body", 400).

@test
pub new_populates_http_error_code(): Bool ->
    std.test.Test.assert_equal(InvalidBody, code(sample_error())).

@test
pub new_populates_http_error_message(): Bool ->
    std.test.Test.assert_equal("invalid request body", message(sample_error())).

@test
pub new_populates_http_error_status(): Bool ->
    std.test.Test.assert_equal(400, status(sample_error())).
