module std.core.EqualTest.

import std.core.Equal.{Equal}.
import std.core.Ordering.{Eq, Lt}.

@test
pub equal_accepts_matching_bool_values(): Bool ->
    std.test.Test.assert(Equal[Bool].equal(true, true)).

@test
pub equal_rejects_different_bool_values(): Bool ->
    std.test.Test.assert_equal(false, Equal[Bool].equal(true, false)).

@test
pub equal_accepts_matching_int_values(): Bool ->
    std.test.Test.assert(Equal[Int].equal(42, 42)).

@test
pub equal_rejects_different_int_values(): Bool ->
    std.test.Test.assert_equal(false, Equal[Int].equal(42, 7)).

@test
pub equal_accepts_matching_float_values(): Bool ->
    std.test.Test.assert(Equal[Float].equal(1.5, 1.5)).

@test
pub equal_rejects_different_float_values(): Bool ->
    std.test.Test.assert_equal(false, Equal[Float].equal(1.5, 2.5)).

@test
pub equal_accepts_matching_string_values(): Bool ->
    std.test.Test.assert(Equal[String].equal("same", "same")).

@test
pub equal_rejects_different_string_values(): Bool ->
    std.test.Test.assert_equal(false, Equal[String].equal("same", "other")).

@test
pub equal_accepts_unit_values(): Bool ->
    std.test.Test.assert(Equal[Unit].equal(Unit, Unit)).

@test
pub equal_accepts_matching_comparison_values(): Bool ->
    std.test.Test.assert(Equal[std.core.Ordering.Comparison].equal(Eq, Eq)).

@test
pub equal_rejects_different_comparison_values(): Bool ->
    std.test.Test.assert_equal(
        false,
        Equal[std.core.Ordering.Comparison].equal(Eq, Lt)
    ).
