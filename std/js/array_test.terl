module tests.js.std.ArrayTest.

import type std.collections.List.
import type std.js.Array.

pub accepts_array(value: Array[Int]): Array[Int] ->
    value.

pub converts_from_list(values: List[Int]): Array[Int] ->
    std.js.Array.from_list(values).

pub converts_to_list(values: Array[Int]): List[Int] ->
    values.to_list().

pub reads_array_length(values: Array[Int]): Int ->
    values.length().

pub reads_array_index(values: Array[Int], index: Int): Int ->
    values.get_at(index).

@test
pub generated_surface_is_declared(): Bool ->
    true.
