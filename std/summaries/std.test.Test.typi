//! Portable test assertions.
//!
//! `std.test.Test` provides Bool-returning assertions used by `terlc test` target
//! runners and generated project tests.

module std.test.Test.

/// Assertion is the portable result value returned by test assertions.
///
/// Input: no runtime input; this is a public type alias.
/// Output: `Bool`, where `true` means pass and `false` means failure.
/// Transformation: gives test helpers a stable stdlib result name without
/// changing the runtime representation.

pub type Assertion =
    Bool.

/// Returns the condition as an assertion result.
///
/// Input: `condition`, the Bool expression being checked.
/// Output: `true` when `condition` is true, otherwise `false`.
/// Transformation: returns `condition` unchanged.

pub assert(condition: Bool): Assertion.

/// Returns whether the two values are exactly equal.
///
/// Input: `left` and `right`, two values of the same type.
/// Output: `true` when `left == right`, otherwise `false`.
/// Transformation: applies Terlan equality to the two inputs.

pub assert_equal(left: A, right: A): Assertion.

/// Returns whether the condition is false.
///
/// Input: `condition`, the Bool expression expected to be false.
/// Output: `true` when `condition` is false, otherwise `false`.
/// Transformation: compares `condition` against `false`.

pub assert_false(condition: Bool): Assertion.

/// Returns whether the two values are not exactly equal.
///
/// Input: `left` and `right`, two values of the same type.
/// Output: `true` when `left != right`, otherwise `false`.
/// Transformation: applies Terlan inequality to the two inputs.

pub assert_not_equal(left: A, right: A): Assertion.

/// Returns the condition as an explicit truth assertion result.
///
/// Input: `condition`, the Bool expression expected to be true.
/// Output: `true` when `condition` is true, otherwise `false`.
/// Transformation: returns `condition` unchanged under the clearer
/// `assert_true` name.

pub assert_true(condition: Bool): Assertion.

/// Returns a failing assertion result.
///
/// Input: no arguments.
/// Output: always `false`.
/// Transformation: returns the portable failing assertion value directly.

pub fail(): Assertion.

