{
  "name": "Terlan",
  "scopeName": "source.terlan",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#interpolation"
    }
  ],
  "repository": {
    "annotations": {
      "patterns": [
        {
          "name": "storage.type.annotation.terlan",
          "match": "@[A-Za-z_][A-Za-z0-9_.]*"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.terlan",
          "begin": "/\\*\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.terlan",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.terlan",
          "match": "//.*$"
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.terlan",
          "begin": "\\$\\{",
          "end": "\\}",
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.terlan",
          "match": "\\b(case|else|if|let|of|with)\\b"
        },
        {
          "name": "keyword.declaration.terlan",
          "match": "\\b(constructor|extends|implements|import|module|opaque|pub|struct|template|trait|type)\\b"
        },
        {
          "name": "constant.language.terlan",
          "match": "\\b(true|false|unit|native)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.terlan",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.terlan",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "include": "#interpolation"
            },
            {
              "name": "constant.character.escape.terlan",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.terlan",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.terlan",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.terlan",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
