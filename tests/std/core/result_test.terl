module std.core.ResultTest.

import std.core.Result.{Err, Ok}.
import type std.core.Result.

pub type Problem =
    Atom["problem"].

pub error_result(): Result[Int, Problem] ->
    Err(Problem).

pub ok_result(): Result[Int, Problem] ->
    Ok(41).

@test
pub ok_constructor_returns_ok_tuple(): Bool ->
    std.test.Test.assert(Ok(42) == Ok(42)).

@test
pub err_constructor_returns_error_tuple(): Bool ->
    std.test.Test.assert(Err(Problem) == Err(Problem)).

@test
pub is_ok_accepts_success(): Bool ->
    std.test.Test.assert_equal(true, std.core.Result.is_ok(ok_result())).

@test
pub is_ok_rejects_error(): Bool ->
    std.test.Test.assert_equal(false, std.core.Result.is_ok(error_result())).

@test
pub is_err_accepts_error(): Bool ->
    std.test.Test.assert_equal(true, std.core.Result.is_err(error_result())).

@test
pub is_err_rejects_success(): Bool ->
    std.test.Test.assert_equal(false, std.core.Result.is_err(ok_result())).

@test
pub map_transforms_success(): Bool ->
    std.test.Test.assert_equal(Ok(42), std.core.Result.map(ok_result(), (value: Int) -> value + 1)).

@test
pub map_preserves_error(): Bool ->
    std.test.Test.assert_equal(Err(Problem), std.core.Result.map(error_result(), (value: Int) -> value + 1)).

@test
pub map_error_preserves_success(): Bool ->
    std.test.Test.assert_equal(Ok(41), std.core.Result.map_error(ok_result(), (reason: Problem) -> reason)).

@test
pub map_error_transforms_error(): Bool ->
    std.test.Test.assert_equal(Err(Problem), std.core.Result.map_error(error_result(), (reason: Problem) -> reason)).

@test
pub and_then_chains_success(): Bool ->
    std.test.Test.assert_equal(Ok(42), std.core.Result.and_then(ok_result(), (value: Int) -> Ok(value + 1))).

@test
pub and_then_preserves_error(): Bool ->
    std.test.Test.assert_equal(Err(Problem), std.core.Result.and_then(error_result(), (value: Int) -> Ok(value + 1))).

@test
pub with_default_uses_success(): Bool ->
    std.test.Test.assert_equal(41, std.core.Result.with_default(ok_result(), 42)).

@test
pub with_default_uses_default_for_error(): Bool ->
    std.test.Test.assert_equal(42, std.core.Result.with_default(error_result(), 42)).
