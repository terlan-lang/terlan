module std.collections.ListTest.

import std.collections.Enumerable.{Enumerable}.
import std.collections.List.
import std.core.Option.

@test
pub new_starts_empty(): Bool ->
    let values = List.new();
    std.test.Test.assert(values.is_empty()).

@test
pub push_updates_length(): Bool ->
    let values = List.new();
    values.push(1);
    values.push(2);
    std.test.Test.assert_equal(2, values.length()).

@test
pub first_returns_present_value(): Bool ->
    let values = List.new();
    values.push(1);
    values.push(2);
    std.test.Test.assert_equal(
        1,
        Option.with_default(values.first(), 0)
    ).

@test
pub first_returns_none_for_empty_list(): Bool ->
    let values = List.new();
    std.test.Test.assert(Option.is_none(values.first())).

@test
pub enumerable_map_transforms_values(): Bool ->
    let values = List.new();
    values.push(1);
    values.push(2);
    let mapped = Enumerable.map(values, (value) -> value + 1);
    std.test.Test.assert_equal(2, std.collections.List.length(mapped)).

@test
pub enumerable_filter_keeps_matching_values(): Bool ->
    let values = List.new();
    values.push(1);
    values.push(2);
    let filtered = Enumerable.filter(values, (value) -> value > 1);
    std.test.Test.assert_equal(1, std.collections.List.length(filtered)).

@test
pub enumerable_fold_accumulates_values(): Bool ->
    let values = List.new();
    values.push(1);
    values.push(2);
    std.test.Test.assert_equal(
        3,
        Enumerable.fold(values, 0, (acc, value) -> acc + value)
    ).

@test
pub enumerable_each_returns_unit(): Bool ->
    let values = List.new();
    values.push(1);
    values.push(2);
    std.test.Test.assert_equal(Unit, Enumerable.each(values, (_value) -> Unit)).

@test
pub clear_removes_values(): Bool ->
    let values = List.new();
    values.push(1);
    values.clear();
    std.test.Test.assert(values.is_empty()).
