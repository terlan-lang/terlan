module std.collections.SetTest.

import std.collections.Enumerable.{Enumerable}.
import std.collections.List.
import std.collections.Set.

@test
pub new_starts_empty(): Bool ->
    let values = Set.new();
    std.test.Test.assert(values.is_empty()).

@test
pub add_updates_size_and_membership(): Bool ->
    let values = Set.new();
    values.add(1);
    values.add(1);
    std.test.Test.assert_equal(1, values.size()).

@test
pub contains_tracks_mutations(): Bool ->
    let values = Set.new();
    values.add(1);
    std.test.Test.assert(values.contains(1)).

@test
pub clear_removes_values(): Bool ->
    let values = Set.new();
    values.add(1);
    values.clear();
    std.test.Test.assert(values.is_empty()).

@test
pub enumerable_fold_accumulates_values(): Bool ->
    let values = Set.new();
    values.add(1);
    values.add(2);
    std.test.Test.assert_equal(
        3,
        Enumerable.fold(values, 0, (acc, value) -> acc + value)
    ).

@test
pub enumerable_map_yields_values(): Bool ->
    let values = Set.new();
    values.add(1);
    values.add(2);
    let mapped = Enumerable.map(values, (value) -> value + 1);
    std.test.Test.assert_equal(2, List.length(mapped)).
